# Binaries
bin/
*.exe
*.dll
*.so
*.dylib

# goreleaser output dir — everything under dist/ is generated. The APT
# signing-key payload lives at apt/key.gpg (outside dist/) so
# `goreleaser release --clean` can wipe dist/ without leaving the tree
# in a "dirty" state. publish-apt.mjs reads from apt/key.gpg.
dist/

# Test artifacts
*.test
*.out
coverage.txt

# Local state
*.db
*.db-journal
*.db-wal
*.db-shm
/var/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Local config that may carry secrets
.env
.env.local
config.local.yaml

# Go
vendor/
