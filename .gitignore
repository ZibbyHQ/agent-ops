# Binaries
bin/
*.exe
*.dll
*.so
*.dylib

# goreleaser output dir — everything under dist/ is generated EXCEPT the
# checked-in APT signing-key payload (scripts/publish-apt.mjs reads it
# from dist/apt/ and uploads it to dl.zibby.app/apt/key.gpg).
dist/*
!dist/apt/

# Test artifacts
*.test
*.out
coverage.txt

# Local state
*.db
*.db-journal
*.db-wal
*.db-shm
/var/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Local config that may carry secrets
.env
.env.local
config.local.yaml

# Go
vendor/
